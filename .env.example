# Slack listener — local dev configuration
# Copy to .env and fill in your token:  cp .env.example .env

# Slack credentials
SLACK_TOKEN=xoxp-your-token-here        # user token for poll mode
# SLACK_APP_TOKEN=xapp-your-token-here  # only needed for socket mode

# Ingestion mode
INGEST_MODE=poll                         # poll (dev) or socket (production)
POLL_INTERVAL=5                          # seconds between polls

# History bounds — prevents full backfill on first run
SLACK_START_FROM=now                     # "now", ISO date (2025-03-01), or epoch

# Channel filtering (optional — auto-discovers if empty)
# SLACK_CHANNEL_IDS=C01ABC123,C02DEF456

# Storage backend
STORAGE_BACKEND=local                    # local, delta, or opensearch
LOCAL_DATA_DIR=./data

# --- Delta Lake (production) ---
# STORAGE_BACKEND=delta
# DELTA_TABLE_NAME=agentsearch.default.slack_messages
# DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
# DATABRICKS_TOKEN=dapi...
# DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/...

# --- OpenSearch (optional) ---
# STORAGE_BACKEND=opensearch
# OPENSEARCH_HOST=localhost
# OPENSEARCH_PORT=9200
